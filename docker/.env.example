# Copy to docker/.env (gitignored) and fill in. docker compose auto-loads it.
# GitHub PAT for git push/pull over HTTPS inside the container.
GH_TOKEN=ghp_replace_me

# Optional: skip Claude browser login by using an API key instead.
# ANTHROPIC_API_KEY=

# Optional: your SSH public key for remote access on port 2224.
# SSH_PUBKEY=ssh-ed25519 AAAA...
